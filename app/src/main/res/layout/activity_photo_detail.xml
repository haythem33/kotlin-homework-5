<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="48dp">

            <!-- Main Header Image -->
            <ImageView
                android:id="@+id/headerImage"
                android:layout_width="0dp"
                android:layout_height="300dp"
                android:scaleType="centerCrop"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:srcCompat="@tools:sample/backgrounds/scenic" />

            <!-- 1. Image Overlay (Location) -->
            <ImageView
                android:id="@+id/icLocation"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="24dp"
                android:layout_marginBottom="24dp"
                android:src="@android:drawable/ic_menu_mylocation"
                app:layout_constraintBottom_toBottomOf="@id/headerImage"
                app:layout_constraintStart_toStartOf="@id/headerImage"
                app:tint="#FFFFFF" />

            <TextView
                android:id="@+id/tvLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Barcelona, Spain"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/icLocation"
                app:layout_constraintStart_toEndOf="@id/icLocation"
                app:layout_constraintTop_toTopOf="@id/icLocation" />

            <!-- 2. Profile Layer -->
            <ImageView
                android:id="@+id/profileImage"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="16dp"
                android:scaleType="centerCrop"
                android:background="@android:drawable/btn_default"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/headerImage"
                tools:srcCompat="@tools:sample/avatars" />

            <TextView
                android:id="@+id/profileName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="Biel Morro"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/profileImage"
                app:layout_constraintStart_toEndOf="@id/profileImage"
                app:layout_constraintTop_toTopOf="@id/profileImage" />

            <ImageView
                android:id="@+id/btnDownload"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="20dp"
                android:src="@android:drawable/stat_sys_download"
                app:layout_constraintBottom_toBottomOf="@id/profileImage"
                app:layout_constraintEnd_toStartOf="@id/btnHeart"
                app:layout_constraintTop_toTopOf="@id/profileImage"
                app:tint="#FFFFFF" />

            <ImageView
                android:id="@+id/btnHeart"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="20dp"
                android:src="@android:drawable/btn_star_big_off"
                app:layout_constraintBottom_toBottomOf="@id/profileImage"
                app:layout_constraintEnd_toStartOf="@id/btnBookmark"
                app:layout_constraintTop_toTopOf="@id/profileImage"
                app:tint="#FFFFFF" />

            <ImageView
                android:id="@+id/btnBookmark"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="24dp"
                android:src="@android:drawable/ic_input_add"
                app:layout_constraintBottom_toBottomOf="@id/profileImage"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/profileImage"
                app:tint="#FFFFFF" />

            <!-- Divider below profile -->
            <View
                android:id="@+id/divider1"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="16dp"
                android:background="#1AFFFFFF"
                app:layout_constraintTop_toBottomOf="@id/profileImage" />

            <!-- Camera Specs Grid -->
            <TextView
                android:id="@+id/labelCamera"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:text="Camera"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toStartOf="@+id/labelAperture"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider1" />

            <TextView
                android:id="@+id/valCamera"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="NIKON D3200"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="@id/labelCamera"
                app:layout_constraintStart_toStartOf="@id/labelCamera"
                app:layout_constraintTop_toBottomOf="@id/labelCamera" />

            <TextView
                android:id="@+id/labelAperture"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="24dp"
                android:text="Aperture"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@+id/labelCamera"
                app:layout_constraintTop_toTopOf="@id/labelCamera" />

            <TextView
                android:id="@+id/valAperture"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="f/5.0"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="@id/labelAperture"
                app:layout_constraintStart_toStartOf="@id/labelAperture"
                app:layout_constraintTop_toBottomOf="@id/labelAperture" />

            <!-- Row 2 -->
            <TextView
                android:id="@+id/labelFocal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Focal Length"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@id/labelCamera"
                app:layout_constraintStart_toStartOf="@id/labelCamera"
                app:layout_constraintTop_toBottomOf="@id/valCamera" />

            <TextView
                android:id="@+id/valFocal"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="18.0mm"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="@id/labelFocal"
                app:layout_constraintStart_toStartOf="@id/labelFocal"
                app:layout_constraintTop_toBottomOf="@id/labelFocal" />

            <TextView
                android:id="@+id/labelShutter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Shutter Speed"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@id/labelAperture"
                app:layout_constraintStart_toStartOf="@id/labelAperture"
                app:layout_constraintTop_toTopOf="@id/labelFocal" />

            <TextView
                android:id="@+id/valShutter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="1/125s"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="@id/labelShutter"
                app:layout_constraintStart_toStartOf="@id/labelShutter"
                app:layout_constraintTop_toBottomOf="@id/labelShutter" />

            <!-- Row 3 -->
            <TextView
                android:id="@+id/labelIso"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="ISO"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@id/labelCamera"
                app:layout_constraintStart_toStartOf="@id/labelCamera"
                app:layout_constraintTop_toBottomOf="@id/valFocal" />

            <TextView
                android:id="@+id/valIso"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="100"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="@id/labelIso"
                app:layout_constraintStart_toStartOf="@id/labelIso"
                app:layout_constraintTop_toBottomOf="@id/labelIso" />

            <TextView
                android:id="@+id/labelDimens"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Dimensions"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="@id/labelAperture"
                app:layout_constraintStart_toStartOf="@id/labelAperture"
                app:layout_constraintTop_toTopOf="@id/labelIso" />

            <TextView
                android:id="@+id/valDimens"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="3906 x 4882"
                android:textColor="#AAAAAA"
                android:textSize="14sp"
                app:layout_constraintEnd_toEndOf="@id/labelDimens"
                app:layout_constraintStart_toStartOf="@id/labelDimens"
                app:layout_constraintTop_toBottomOf="@id/labelDimens" />

            <View
                android:id="@+id/divider2"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                android:background="#1AFFFFFF"
                app:layout_constraintTop_toBottomOf="@id/valIso" />

            <!-- Stats Row -->
            <LinearLayout
                android:id="@+id/statsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                android:paddingHorizontal="24dp"
                app:layout_constraintTop_toBottomOf="@id/divider2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Views" android:textColor="#FFFFFF" android:textSize="12sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="8.8M" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Downloads" android:textColor="#FFFFFF" android:textSize="12sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="99.1K" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Likes" android:textColor="#FFFFFF" android:textSize="12sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1.8K" android:textColor="#FFFFFF" android:textSize="14sp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:id="@+id/divider3"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:background="#1AFFFFFF"
                app:layout_constraintTop_toBottomOf="@id/statsRow" />

            <!-- 3. Bottom Pill Tags -->
            <LinearLayout
                android:id="@+id/tagsRow"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="24dp"
                android:orientation="horizontal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider3">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/tag_background"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="barcelona"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/tag_background"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:text="spain"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>